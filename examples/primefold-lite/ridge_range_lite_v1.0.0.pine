//@version=5
// ============================================================
// PRIMEFOLD CONTINUITY REGISTRY
// Module: Ridge Range Lite -- INDICATOR (Free Tier)
// Version: v1.0.0
// Module Code: RR-LITE
// (c) 2026 PrimeFold.Tools - PrimeFold Trading
// ============================================================
// Purpose: Free structure classifier. Detects swing pivots and
//   derives market structure state (Bullish / Bearish / Neutral).
//   Visual-only -- no alerts, no BOS/CHoCH events, no signals.
//
// Full structure break signals, BOS/CHoCH alerts, and confirmation available in PrimeFold Command -- primefold.tools
// ============================================================

indicator("PF - Ridge Range Lite v1.0.0", shorttitle="PF-RR-Lite", overlay=true, max_lines_count=4)

// ============================================================================
// PRIMEFOLD DESIGN SYSTEM v3.1 -- CONSTANTS
// ============================================================================

var color BULLISH_GREEN  = #10B981
var color BEARISH_RED    = #EF4444
var color NEUTRAL_AMBER  = #F59E0B
var color COGNITIVE_BLUE = #7AA2F7
var color TEXT_DIM       = #999999
var color TEXT_PRIMARY   = #FFFFFF
var color BG_PRIMARY     = #121212
var color DIVIDER        = #2A2A2A
var color FRAME_WHITE    = #FFFFFF

// ============================================================================
// INPUTS
// ============================================================================

var string GRP_SWING = "Swing Engine"
int i_swing_len = input.int(10, "Swing Lookback", minval=2, maxval=50, group=GRP_SWING,
  tooltip="Number of bars on each side to confirm a swing pivot. Lower = more sensitive, higher = fewer pivots.")

var string GRP_VIS = "Visuals"
bool i_show_lines = input.bool(true, "Show Swing Level Lines", group=GRP_VIS)
bool i_show_bg    = input.bool(true, "Show Structure Background", group=GRP_VIS)
bool i_show_dash  = input.bool(true, "Show Dashboard", group=GRP_VIS)

// ============================================================================
// SWING PIVOT DETECTION (non-repaint: barstate.isconfirmed gate)
// ============================================================================

float pivot_high_raw = ta.pivothigh(high, i_swing_len, i_swing_len)
float pivot_low_raw  = ta.pivotlow(low,  i_swing_len, i_swing_len)

var float last_swing_high  = na
var float last_swing_low   = na
var float prev_swing_high  = na
var float prev_swing_low   = na

if barstate.isconfirmed
    if not na(pivot_high_raw)
        prev_swing_high := last_swing_high
        last_swing_high := pivot_high_raw
    if not na(pivot_low_raw)
        prev_swing_low := last_swing_low
        last_swing_low := pivot_low_raw

// ============================================================================
// STRUCTURE STATE CLASSIFIER
// ============================================================================
// Bullish: higher high AND higher low
// Bearish: lower high AND lower low
// Neutral: mixed or insufficient data

var int structure = 0  // -1=bearish, 0=neutral, 1=bullish

if barstate.isconfirmed
    bool have_data = not na(last_swing_high) and not na(prev_swing_high) and not na(last_swing_low) and not na(prev_swing_low)
    if have_data
        bool higher_high = last_swing_high > prev_swing_high
        bool higher_low  = last_swing_low  > prev_swing_low
        bool lower_high  = last_swing_high < prev_swing_high
        bool lower_low   = last_swing_low  < prev_swing_low
        if higher_high and higher_low
            structure := 1
        else if lower_high and lower_low
            structure := -1
        else
            structure := 0

// ============================================================================
// VISUALS -- Swing Level Lines
// ============================================================================

var line ln_high = na
var line ln_low  = na

if barstate.islast and i_show_lines
    // Swing High level
    if not na(last_swing_high)
        if not na(ln_high)
            line.delete(ln_high)
        ln_high := line.new(bar_index - 40, last_swing_high, bar_index + 10, last_swing_high,
          color=BEARISH_RED, style=line.style_dashed, width=1)
    // Swing Low level
    if not na(last_swing_low)
        if not na(ln_low)
            line.delete(ln_low)
        ln_low := line.new(bar_index - 40, last_swing_low, bar_index + 10, last_swing_low,
          color=BULLISH_GREEN, style=line.style_dashed, width=1)

// ============================================================================
// VISUALS -- Structure Background
// ============================================================================

color bg_col = i_show_bg ? (structure == 1 ? color.new(BULLISH_GREEN, 92) : structure == -1 ? color.new(BEARISH_RED, 92) : na) : na
bgcolor(bg_col, title="Structure Background")

// ============================================================================
// DASHBOARD
// ============================================================================

var table dash = table.new(position.top_right, 2, 5, bgcolor=BG_PRIMARY, frame_color=FRAME_WHITE, frame_width=1, border_width=1, border_color=DIVIDER)

if barstate.islast and i_show_dash
    // Row 0: Header
    table.cell(dash, 0, 0, "RIDGE RANGE LITE", bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.small)
    table.cell(dash, 1, 0, "v1.0.0",           bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.tiny)

    // Row 1: Structure State
    string state_txt = structure == 1 ? "BULLISH STRUCTURE" : structure == -1 ? "BEARISH STRUCTURE" : "NEUTRAL"
    color  state_clr = structure == 1 ? BULLISH_GREEN : structure == -1 ? BEARISH_RED : NEUTRAL_AMBER
    table.cell(dash, 0, 1, "Structure", text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 1, state_txt,   text_color=state_clr, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 2: Last Swing High
    string sh_txt = not na(last_swing_high) ? str.tostring(last_swing_high, format.mintick) : "--"
    table.cell(dash, 0, 2, "Swing High", text_color=TEXT_DIM,    text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 2, sh_txt,       text_color=BEARISH_RED, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 3: Last Swing Low
    string sl_txt = not na(last_swing_low) ? str.tostring(last_swing_low, format.mintick) : "--"
    table.cell(dash, 0, 3, "Swing Low", text_color=TEXT_DIM,     text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 3, sl_txt,      text_color=BULLISH_GREEN, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 4: Footer / CTA
    table.cell(dash, 0, 4, "PrimeFold Trading", text_color=TEXT_DIM, text_size=size.tiny, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 4, "FREE",               text_color=NEUTRAL_AMBER, text_size=size.tiny, bgcolor=BG_PRIMARY)

// ============================================================================
// CHANGELOG
// ============================================================================
//
// v1.0.0 (2026-03-21) -- INITIAL LITE RELEASE
//   Free-tier structure classifier derived from Ridge Range v0.5.2.
//   INCLUDES: Swing pivot detection (configurable lookback), structure
//     state classifier (Bullish/Bearish/Neutral via HH/HL vs LH/LL),
//     swing high/low horizontal level lines, structure background color,
//     dashboard with state + swing levels.
//   EXCLUDES: BOS/CHoCH event markers, break confirmation signals, alerts,
//     order blocks, quality composite, bridge schema, strategy execution.
//   Non-repaint: all state updates gated on barstate.isconfirmed.
//
// Full structure break signals, BOS/CHoCH alerts, and confirmation available in PrimeFold Command -- primefold.tools
//
