//@version=5
// ============================================================
// PRIMEFOLD CONTINUITY REGISTRY
// Module: Trend Terrain Lite — INDICATOR (Free Tier)
// Version: v1.0.0
// Design System: v3.1
// (c) 2026 PrimeFold.Tools - PrimeFold Trading
// ============================================================
// Free trend-reading overlay. Shows trend state, quality, and
// EMA ribbon — no signals, no alerts, no entry timing.
//
// Full signals, alerts, and entry timing available in PrimeFold Command — primefold.tools
// ============================================================

indicator("PF - Trend Terrain Lite v1.0.0", shorttitle="PF-TT-Lite", overlay=true)

// ============================================================================
// PRIMEFOLD DESIGN SYSTEM v3.1 — IMMUTABLE CONSTANTS
// ============================================================================

var color BULLISH_GREEN  = #10B981
var color NEUTRAL_AMBER  = #F59E0B
var color BEARISH_RED    = #EF4444
var color COGNITIVE_BLUE = #7AA2F7
var color TEXT_DIM       = #999999
var color TEXT_PRIMARY   = #FFFFFF
var color BG_PRIMARY     = #121212
var color DIVIDER        = #2A2A2A
var color FRAME_WHITE    = #FFFFFF

// ============================================================================
// INPUT GROUPS
// ============================================================================

string GRP_PRESET = "Smart Presets"
string GRP_CORE   = "Core Trend"
string GRP_SCORE  = "Scoring"

// ============================================================================
// INPUTS — SMART PRESETS
// ============================================================================

i_tf_preset = input.string("Custom", "Timeframe Preset",
     options=["Custom", "Scalp (1m-5m)", "Day Trade (5m-15m)", "Swing (1H-4H)", "Position (Daily+)"],
     group=GRP_PRESET,
     tooltip="Auto-configure base parameters for your timeframe. 'Custom' lets you tune every parameter manually.")

i_asset_preset = input.string("Custom", "Asset Class",
     options=["Custom", "Crypto", "Forex", "Stocks", "Indices"],
     group=GRP_PRESET,
     tooltip="Adjust parameters for asset volatility profile.")

// ============================================================================
// INPUTS — CORE TREND
// ============================================================================

i_ema_fast_len_input = input.int(21,     "EMA Fast Length",            minval=5,    maxval=50,   group=GRP_CORE)
i_ema_slow_len_input = input.int(55,     "EMA Slow Length",            minval=20,   maxval=200,  group=GRP_CORE)
i_slope_len          = input.int(10,     "Slope Lookback (bars)",      minval=5,    maxval=20,   group=GRP_CORE)
i_slope_min_input    = input.float(0.03, "Slope Dead-Zone (ATR/bar)",  minval=0.01, maxval=0.10, step=0.005, group=GRP_CORE)
i_hysteresis_input   = input.float(0.15, "Hysteresis (x ATR)",         minval=0.05, maxval=0.50, step=0.01,  group=GRP_CORE)

// ============================================================================
// INPUTS — SCORING
// ============================================================================

i_sep_weight  = input.int(50,      "Separation Weight",        minval=0,   maxval=100,  group=GRP_SCORE)
i_slope_weight= input.int(50,      "Slope Weight",             minval=0,   maxval=100,  group=GRP_SCORE)
i_sep_cap     = input.float(1.0,   "Separation Soft Cap (ATR)",minval=0.5, maxval=2.0,  step=0.1, group=GRP_SCORE)
i_slope_cap   = input.float(0.20,  "Slope Soft Cap (ATR/bar)", minval=0.05,maxval=0.50, step=0.01,group=GRP_SCORE)

// ============================================================================
// SMART PRESET OVERRIDE LOGIC
// ============================================================================

int   i_ema_fast_len     = i_ema_fast_len_input
int   i_ema_slow_len     = i_ema_slow_len_input
float i_slope_min        = i_slope_min_input
float i_hysteresis_mult  = i_hysteresis_input

if i_tf_preset == "Scalp (1m-5m)"
    i_ema_fast_len    := 8
    i_ema_slow_len    := 21
    i_slope_min       := 0.05
    i_hysteresis_mult := 0.10
else if i_tf_preset == "Day Trade (5m-15m)"
    i_ema_fast_len    := 13
    i_ema_slow_len    := 34
    i_slope_min       := 0.04
    i_hysteresis_mult := 0.12
else if i_tf_preset == "Swing (1H-4H)"
    i_ema_fast_len    := 21
    i_ema_slow_len    := 55
    i_slope_min       := 0.03
    i_hysteresis_mult := 0.15
else if i_tf_preset == "Position (Daily+)"
    i_ema_fast_len    := 34
    i_ema_slow_len    := 89
    i_slope_min       := 0.02
    i_hysteresis_mult := 0.20

float asset_mult = 1.0
if i_asset_preset == "Crypto"
    asset_mult := 1.6
else if i_asset_preset == "Forex"
    asset_mult := 0.7
else if i_asset_preset == "Stocks"
    asset_mult := 1.0
else if i_asset_preset == "Indices"
    asset_mult := 0.85

i_hysteresis_mult := i_hysteresis_mult * asset_mult
i_slope_min       := i_slope_min * asset_mult

// ============================================================================
// CORE CALCULATIONS
// ============================================================================

float ema_fast  = ta.ema(close, i_ema_fast_len)
float ema_slow  = ta.ema(close, i_ema_slow_len)
float atr_val   = ta.atr(14)

float ema_slope  = (ema_fast - ema_fast[i_slope_len]) / i_slope_len
float separation = atr_val > 0 ? math.abs(ema_fast - ema_slow) / atr_val : 0.0
float slope_norm = atr_val > 0 ? math.abs(ema_slope) / atr_val : 0.0

float hyst_band = i_hysteresis_mult * atr_val

// ============================================================================
// STATE MACHINE — TRUE HYSTERESIS (from v2.5.1)
// ============================================================================

var int state_code = 2  // 1=DOWNTREND, 2=NEUTRAL, 3=UPTREND

float flip_band = hyst_band
float hold_band = hyst_band * 0.60

bool is_up_raw   = (ema_fast - ema_slow) > flip_band and ema_slope > 0 and slope_norm > i_slope_min
bool is_down_raw = (ema_slow - ema_fast) > flip_band and ema_slope < 0 and slope_norm > i_slope_min

if barstate.isconfirmed
    if state_code == 3
        state_code := (ema_fast - ema_slow) > hold_band and ema_slope > 0 ? 3 :
                      is_down_raw ? 1 : 2
    else if state_code == 1
        state_code := (ema_slow - ema_fast) > hold_band and ema_slope < 0 ? 1 :
                      is_up_raw ? 3 : 2
    else
        state_code := is_up_raw ? 3 : is_down_raw ? 1 : 2

// ============================================================================
// QUALITY SCORE (0-100)
// ============================================================================

float sep_n       = math.min(separation / i_sep_cap, 1.0)
float slope_n     = math.min(slope_norm / i_slope_cap, 1.0)
float w_raw_sep   = i_sep_weight / 100.0
float w_raw_slope = i_slope_weight / 100.0
float w_sum       = w_raw_sep + w_raw_slope
float w_sep       = w_sum == 0 ? 0.5 : w_raw_sep / w_sum
float w_slope     = w_sum == 0 ? 0.5 : w_raw_slope / w_sum
float quality     = 100.0 * (w_sep * sep_n + w_slope * slope_n)

var float confirmed_quality = 0.0
if barstate.isconfirmed
    confirmed_quality := quality

// ============================================================================
// TREND AGE
// ============================================================================

var int trend_age = 0
if barstate.isconfirmed
    bool is_trending = state_code == 1 or state_code == 3
    if is_trending and state_code == state_code[1]
        trend_age += 1
    else if is_trending and state_code != state_code[1]
        trend_age := 1
    else
        trend_age := 0

f_trend_age_label(int bars) =>
    bars == 0 ? "---" : bars < 5 ? "FRESH" : bars < 20 ? "BUILDING" : bars < 50 ? "MATURE" : "EXTENDED"

// ============================================================================
// VISUALS — EMA RIBBON + BACKGROUND TINT
// ============================================================================

plot(ema_fast, "EMA Fast", color=COGNITIVE_BLUE, linewidth=2)
plot(ema_slow, "EMA Slow", color=TEXT_DIM, linewidth=1)

p_f = plot(ema_fast, display=display.none)
p_s = plot(ema_slow, display=display.none)
color ribbon_color = state_code == 3 ? color.new(BULLISH_GREEN, 85) :
                     state_code == 1 ? color.new(BEARISH_RED, 85) : na
fill(p_f, p_s, color=ribbon_color, title="Trend Ribbon")

bgcolor(state_code == 3 ? color.new(BULLISH_GREEN, 94) :
        state_code == 1 ? color.new(BEARISH_RED, 94) : na,
        title="Trend Background")

// ============================================================================
// DASHBOARD (5 rows)
// ============================================================================

var table dash = table.new(position.bottom_right, 2, 5,
     bgcolor=BG_PRIMARY, frame_color=FRAME_WHITE, frame_width=2,
     border_width=1, border_color=DIVIDER)

if barstate.islast
    // Row 0 — Header
    table.cell(dash, 0, 0, "Trend Terrain Lite", bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.small)
    table.cell(dash, 1, 0, "v1.0.0",             bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.tiny)

    // Row 1 — Trend State
    string state_txt = state_code == 3 ? "UPTREND" : state_code == 1 ? "DOWNTREND" : "NEUTRAL"
    color  state_clr = state_code == 3 ? BULLISH_GREEN : state_code == 1 ? BEARISH_RED : NEUTRAL_AMBER
    table.cell(dash, 0, 1, "Trend",    text_color=TEXT_DIM,  text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 1, state_txt,  text_color=state_clr, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 2 — Quality Score
    color q_clr = confirmed_quality >= 60 ? BULLISH_GREEN : confirmed_quality >= 40 ? NEUTRAL_AMBER : TEXT_DIM
    table.cell(dash, 0, 2, "Quality",  text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 2, str.tostring(math.round(confirmed_quality, 0)) + "%", text_color=q_clr, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 3 — Trend Age
    string age_txt = trend_age > 0 ? f_trend_age_label(trend_age) + " (" + str.tostring(trend_age) + "b)" : "---"
    table.cell(dash, 0, 3, "Age",      text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 3, age_txt,    text_color=state_code == 2 ? TEXT_DIM : TEXT_PRIMARY, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 4 — Footer
    table.cell(dash, 0, 4, "PrimeFold Trading",  text_color=TEXT_DIM, text_size=size.tiny, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 4, "FREE",                text_color=NEUTRAL_AMBER, text_size=size.tiny, bgcolor=BG_PRIMARY)

// ============================================================================
// END — Trend Terrain Lite v1.0.0
// ============================================================================
