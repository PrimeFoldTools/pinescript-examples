// @version=5
// ============================================================
// PRIMEFOLD CONTINUITY REGISTRY
// Module: Tide Turn Lite — INDICATOR (Free Tier)
// Version: v1.0.0
// Module Code: 2 (TD)
// (c) 2026 PrimeFold.Tools - PrimeFold Trading
// ============================================================
// Purpose: Free exhaustion gauge. Dual Williams %R with zone
//   detection. Read-only — no signals, no alerts, no exits.
// Full exhaustion signals, alerts, and Slipstream temporal coherence available in PrimeFold Command — primefold.tools
// ============================================================

indicator("PF - Tide Turn Lite v1.0.0", shorttitle="PF-TD-Lite", overlay=false)

// ============================================================================
// PRIMEFOLD DESIGN SYSTEM v3.1 — IMMUTABLE CONSTANTS
// ============================================================================

var color BULLISH_GREEN  = #10B981
var color NEUTRAL_AMBER  = #F59E0B
var color BEARISH_RED    = #EF4444
var color COGNITIVE_BLUE = #7AA2F7
var color TEXT_DIM       = #999999
var color TEXT_PRIMARY   = #FFFFFF
var color BG_PRIMARY     = #121212
var color DIVIDER        = #2A2A2A
var color FRAME_WHITE    = #FFFFFF

var color BG_OVERSOLD    = color.new(BULLISH_GREEN, 88)
var color BG_OVERBOUGHT  = color.new(BEARISH_RED, 88)

// ============================================================================
// INPUTS — WILLIAMS %R CONFIGURATION
// ============================================================================

string GRP_WR = "Williams %R"

src              = input.source(close, "Source", group=GRP_WR, tooltip="Price source for %R numerator. HH/LL always use high/low.")
shortLength      = input.int(21, "Fast Length", minval=1, group=GRP_WR)
shortSmoothing   = input.int(7, "Fast Smoothing", minval=1, group=GRP_WR)
longLength       = input.int(112, "Slow Length", minval=1, group=GRP_WR)
longSmoothing    = input.int(3, "Slow Smoothing", minval=1, group=GRP_WR)

// ============================================================================
// WILLIAMS %R CALCULATION
// ============================================================================

_pr(int len) =>
    float hh = ta.highest(high, len)
    float ll = ta.lowest(low, len)
    100 * (src - hh) / math.max(hh - ll, 1e-10)

// Raw %R
float s_raw = _pr(shortLength)
float l_raw = _pr(longLength)

// EMA smoothing
float s_percentR = shortSmoothing > 1 ? ta.ema(s_raw, shortSmoothing) : s_raw
float l_percentR = longSmoothing  > 1 ? ta.ema(l_raw, longSmoothing)  : l_raw

// ============================================================================
// EXHAUSTION ZONE DETECTION (non-repaint)
// ============================================================================

var string state = "MID-RANGE"

bool isOversold   = s_percentR <= -80 and l_percentR <= -80
bool isOverbought = s_percentR >= -20 and l_percentR >= -20

if barstate.isconfirmed
    if isOversold
        state := "OVERSOLD"
    else if isOverbought
        state := "OVERBOUGHT"
    else
        state := "MID-RANGE"

// ============================================================================
// PLOTS — %R LINES & ZONE LEVELS
// ============================================================================

plot(s_percentR, "Fast %R (21)", color=COGNITIVE_BLUE, linewidth=2)
plot(l_percentR, "Slow %R (112)", color=NEUTRAL_AMBER, linewidth=2)

hline(-20, "Overbought", color=color.new(BEARISH_RED, 50), linestyle=hline.style_dashed)
hline(-80, "Oversold",   color=color.new(BULLISH_GREEN, 50), linestyle=hline.style_dashed)
hline(-50, "Mid",        color=color.new(TEXT_DIM, 70), linestyle=hline.style_dotted)

// ============================================================================
// BACKGROUND — ZONE TINTING
// ============================================================================

bgcolor(isOversold ? BG_OVERSOLD : isOverbought ? BG_OVERBOUGHT : na)

// ============================================================================
// DASHBOARD
// ============================================================================

var table dash = table.new(position.top_right, 2, 5, bgcolor=BG_PRIMARY, frame_color=FRAME_WHITE, frame_width=2, border_width=1, border_color=DIVIDER)

if barstate.islast
    // Row 0 — Header
    table.cell(dash, 0, 0, "TIDE TURN LITE", bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.small)
    table.cell(dash, 1, 0, "v1.0.0",         bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.tiny)

    // Row 1 — Exhaustion State
    color state_clr = state == "OVERSOLD" ? BULLISH_GREEN : state == "OVERBOUGHT" ? BEARISH_RED : NEUTRAL_AMBER
    table.cell(dash, 0, 1, "State",  text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 1, state,    text_color=state_clr, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 2 — Fast %R
    table.cell(dash, 0, 2, "Fast %R", text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 2, str.tostring(math.round(s_percentR, 2)), text_color=COGNITIVE_BLUE, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 3 — Slow %R
    table.cell(dash, 0, 3, "Slow %R", text_color=TEXT_DIM, text_size=size.small, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 3, str.tostring(math.round(l_percentR, 2)), text_color=NEUTRAL_AMBER, text_size=size.small, bgcolor=BG_PRIMARY)

    // Row 4 — Footer / CTA
    table.cell(dash, 0, 4, "PrimeFold Trading", text_color=TEXT_DIM, text_size=size.tiny, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 4, "FREE",               text_color=TEXT_DIM, text_size=size.tiny, bgcolor=BG_PRIMARY)

// ============================================================================
// END — TIDE TURN LITE v1.0.0
