// @version=5
// ============================================================
// PRIMEFOLD CONTINUITY REGISTRY
// Module: Strike Zone Lite — FREE TIER
// Version: v1.0.0
// Module Code: SZ-LITE
// (c) 2026 PrimeFold.Tools - PrimeFold Trading
// ============================================================
// Purpose: Phase coherence awareness tool. Shows whether
//   Phase A (exhaustion) and Phase B (rotation) are aligning
//   to form a potential setup — without firing the signal.
// ============================================================
// Full tiered signals (PLATINUM/GOLD/SILVER/BRONZE), alerts, and temporal coherence scoring available in PrimeFold Command — primefold.tools
// ============================================================

indicator("PF - Strike Zone Lite v1.0.0", shorttitle="PF-SZ-LITE", overlay=true)

// ============================================================================
// PRIMEFOLD DESIGN SYSTEM v3.1 — IMMUTABLE CONSTANTS
// ============================================================================
var color BG_PRIMARY     = #121212
var color SURFACE        = #1E1E1E
var color DIVIDER        = #2A2A2A
var color TEXT_PRIMARY   = #FFFFFF
var color TEXT_DIM       = #999999
var color COGNITIVE_BLUE = #7AA2F7
var color BULLISH_GREEN  = #10B981
var color NEUTRAL_AMBER  = #F59E0B
var color BEARISH_RED    = #EF4444
var color SETUP_TINT_LONG  = color.new(BULLISH_GREEN, 88)
var color SETUP_TINT_SHORT = color.new(BEARISH_RED, 88)
var color FRAME_WHITE    = #FFFFFF

// ============================================================================
// INPUTS
// ============================================================================
fastR_len  = input.int(21,  "Fast %R Length",   minval=5,  maxval=100, group="Phase A — Exhaustion")
slowR_len  = input.int(112, "Slow %R Length",   minval=20, maxval=200, group="Phase A — Exhaustion")
wrThresh   = input.int(20,  "Extreme Threshold", minval=5, maxval=40,  group="Phase A — Exhaustion")
slowR_lc   = input.int(-60, "Slow Confirm Long",  minval=-80, maxval=-30, group="Phase A — Exhaustion")
slowR_sc   = input.int(-40, "Slow Confirm Short", minval=-70, maxval=-20, group="Phase A — Exhaustion")

k1_len = input.int(9,  "Stoch 1", minval=3,  maxval=50,  group="Phase B — Rotation")
k2_len = input.int(14, "Stoch 2", minval=5,  maxval=50,  group="Phase B — Rotation")
k3_len = input.int(40, "Stoch 3", minval=10, maxval=100, group="Phase B — Rotation")
k4_len = input.int(60, "Stoch 4", minval=20, maxval=200, group="Phase B — Rotation")

cohWindow = input.int(8, "Coherence Window", minval=3, maxval=20, group="Coherence")

// ============================================================================
// PHASE A: EXHAUSTION ENGINE (Williams %R)
// ============================================================================
f_percentR(len) =>
    hh = ta.highest(high, len)
    ll = ta.lowest(low, len)
    rng = hh - ll
    rng == 0 ? -50.0 : ((close - hh) / rng) * 100

fastR = f_percentR(fastR_len)
slowR = f_percentR(slowR_len)
osLevel = -100 + wrThresh
obLevel = 0 - wrThresh

var bool phaseA_long_state  = false
var bool phaseA_short_state = false

bool phaseA_long_fire  = barstate.isconfirmed and fastR[1] < osLevel and fastR > osLevel and slowR < slowR_lc
bool phaseA_short_fire = barstate.isconfirmed and fastR[1] > obLevel and fastR < obLevel and slowR > slowR_sc

if barstate.isconfirmed
    if phaseA_long_fire
        phaseA_long_state := true
    if phaseA_short_fire
        phaseA_short_state := true

// ============================================================================
// PHASE B: ROTATION ENGINE (Quad Stochastic)
// ============================================================================
f_stoch(len) =>
    ta.sma(ta.stoch(close, high, low, len), 3)

stoch1 = f_stoch(k1_len)
stoch2 = f_stoch(k2_len)
stoch3 = f_stoch(k3_len)
stoch4 = f_stoch(k4_len)

float d1 = ta.change(stoch1)
float d2 = ta.change(stoch2)
float d3 = ta.change(stoch3)
float d4 = ta.change(stoch4)

rot_up = (stoch1 < 30 and d1 > 0 ? 1 : 0) +
         (stoch2 < 35 and d2 > 0 ? 1 : 0) +
         (stoch3 < 40 and d3 > 0 ? 1 : 0) +
         (stoch4 < 45 and d4 > 0 ? 1 : 0)
rot_dn = (stoch1 > 70 and d1 < 0 ? 1 : 0) +
         (stoch2 > 65 and d2 < 0 ? 1 : 0) +
         (stoch3 > 60 and d3 < 0 ? 1 : 0) +
         (stoch4 > 55 and d4 < 0 ? 1 : 0)

var bool phaseB_long_state  = false
var bool phaseB_short_state = false

bool phaseB_long_fire  = barstate.isconfirmed and rot_up >= 2
bool phaseB_short_fire = barstate.isconfirmed and rot_dn >= 2

if barstate.isconfirmed
    if phaseB_long_fire
        phaseB_long_state := true
    if phaseB_short_fire
        phaseB_short_state := true

// ============================================================================
// COHERENCE: PHASE ALIGNMENT DETECTION
// ============================================================================
barsA_long  = nz(ta.barssince(phaseA_long_fire),  999)
barsB_long  = nz(ta.barssince(phaseB_long_fire),  999)
barsA_short = nz(ta.barssince(phaseA_short_fire), 999)
barsB_short = nz(ta.barssince(phaseB_short_fire), 999)

bool A_long_recent  = barsA_long  <= cohWindow
bool B_long_recent  = barsB_long  <= cohWindow
bool A_short_recent = barsA_short <= cohWindow
bool B_short_recent = barsB_short <= cohWindow

bool setupLong  = A_long_recent  and B_long_recent
bool setupShort = A_short_recent and B_short_recent
bool setupActive = setupLong or setupShort

// Decay phase states outside coherence window
if barstate.isconfirmed
    if not A_long_recent
        phaseA_long_state := false
    if not A_short_recent
        phaseA_short_state := false
    if not B_long_recent
        phaseB_long_state := false
    if not B_short_recent
        phaseB_short_state := false

// ============================================================================
// VISUAL: BACKGROUND TINT WHEN SETUP FORMING
// ============================================================================
bgcolor(setupLong and not setupShort ? SETUP_TINT_LONG : setupShort and not setupLong ? SETUP_TINT_SHORT : setupLong and setupShort ? color.new(NEUTRAL_AMBER, 90) : na, title="Setup Background")

// ============================================================================
// DASHBOARD
// ============================================================================
var table dash = table.new(position.top_right, 2, 6, bgcolor=BG_PRIMARY, frame_color=FRAME_WHITE, frame_width=2, border_width=1, border_color=DIVIDER)

if barstate.islast
    // Row 0 — Header
    table.cell(dash, 0, 0, "STRIKE ZONE", bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.small)
    table.cell(dash, 1, 0, "LITE",         bgcolor=COGNITIVE_BLUE, text_color=TEXT_PRIMARY, text_size=size.small)

    // Row 1 — Phase A
    bool phaseA_active = phaseA_long_state or phaseA_short_state
    string phaseA_txt  = phaseA_long_state and phaseA_short_state ? "DUAL" : phaseA_long_state ? "LONG" : phaseA_short_state ? "SHORT" : "---"
    color  phaseA_clr  = phaseA_long_state ? BULLISH_GREEN : phaseA_short_state ? BEARISH_RED : TEXT_DIM
    table.cell(dash, 0, 1, "Phase A", text_color=TEXT_DIM,  text_size=size.small, bgcolor=SURFACE)
    table.cell(dash, 1, 1, phaseA_txt, text_color=phaseA_clr, text_size=size.small, bgcolor=SURFACE)

    // Row 2 — Phase B
    bool phaseB_active = phaseB_long_state or phaseB_short_state
    string phaseB_txt  = phaseB_long_state and phaseB_short_state ? "DUAL" : phaseB_long_state ? "LONG" : phaseB_short_state ? "SHORT" : "---"
    color  phaseB_clr  = phaseB_long_state ? BULLISH_GREEN : phaseB_short_state ? BEARISH_RED : TEXT_DIM
    table.cell(dash, 0, 2, "Phase B", text_color=TEXT_DIM,  text_size=size.small, bgcolor=SURFACE)
    table.cell(dash, 1, 2, phaseB_txt, text_color=phaseB_clr, text_size=size.small, bgcolor=SURFACE)

    // Row 3 — Coherence
    string coh_txt = setupLong and setupShort ? "DUAL SETUP" : setupLong ? "SETUP" : setupShort ? "SETUP" : "NO SETUP"
    color  coh_clr = setupActive ? NEUTRAL_AMBER : TEXT_DIM
    table.cell(dash, 0, 3, "Coherence", text_color=TEXT_DIM, text_size=size.small, bgcolor=SURFACE)
    table.cell(dash, 1, 3, coh_txt,     text_color=coh_clr,  text_size=size.small, bgcolor=SURFACE)

    // Row 4 — Direction hint (when setup active)
    string dir_txt = setupLong and setupShort ? "BOTH" : setupLong ? "BULLISH" : setupShort ? "BEARISH" : "---"
    color  dir_clr = setupLong and not setupShort ? BULLISH_GREEN : setupShort and not setupLong ? BEARISH_RED : setupActive ? NEUTRAL_AMBER : TEXT_DIM
    table.cell(dash, 0, 4, "Bias", text_color=TEXT_DIM, text_size=size.small, bgcolor=SURFACE)
    table.cell(dash, 1, 4, dir_txt, text_color=dir_clr, text_size=size.small, bgcolor=SURFACE)

    // Row 5 — Footer
    table.cell(dash, 0, 5, "PrimeFold Trading",  text_color=TEXT_DIM, text_size=size.tiny, bgcolor=BG_PRIMARY)
    table.cell(dash, 1, 5, "FREE", text_color=COGNITIVE_BLUE, text_size=size.tiny, bgcolor=BG_PRIMARY)

// ============================================================================
// END — Strike Zone Lite v1.0.0
// ============================================================================
// Full tiered signals (PLATINUM/GOLD/SILVER/BRONZE), alerts, and temporal coherence scoring available in PrimeFold Command — primefold.tools
// ============================================================================
